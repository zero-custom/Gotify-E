# Gotify[E] 网关配置
# 复制为 .env 并修改，或直接 export 环境变量

# Gotify 后端地址（必填）
GOTIFY_BACKEND=http://localhost:8080

# 网关公网地址（必填，客户端访问网关的地址）
# 留空则自动从请求头推断（适用于反向代理场景）
PUBLIC_URL=

# 监听地址和端口
HOST=0.0.0.0
PORT=8765

# 文件上传存储路径（默认为 /data，与 /app 分离实现存算分离）
# UPLOAD_DIR=/data

# 存储标记（存入消息体中的占位符，读取时自动替换为 PUBLIC_URL）
# STORED_MARKER={gateway}

# 单文件上传上限（单位 MB，默认 50）
# MAX_UPLOAD_MB=50
