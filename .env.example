# Gotify[E] 网关配置
# 复制为 .env 并修改，或直接 export 环境变量

# Gotify 后端地址（必填）
GOTIFY_BACKEND=http://localhost:8080

# 网关公网域名白名单（逗号分隔），用于文件 URL 重写
# 留空则自动从请求 Host 头推断（有 Host 头注入风险，建议显式设置）
PUBLIC_HOST=

# 监听地址和端口
HOST=0.0.0.0
PORT=8765

# 单文件上传上限（单位 MB，默认 50）
# MAX_UPLOAD_MB=50

# 每次请求允许上传的最大文件数（默认 5）
# MAX_FILES_PER_REQUEST=5

# 暂存文件超时时间（分钟，默认 120）
# PENDING_TIMEOUT_MINUTES=120

# 暂存目录清理间隔（分钟，默认 30）
# CLEANUP_INTERVAL_MINUTES=30
